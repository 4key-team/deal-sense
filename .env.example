LLM_PROVIDER=anthropic
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=sk-ant-api03-your-key-here
LLM_MODEL=claude-sonnet-4-5
LLM_SOCKS5_PROXY=socks5://127.0.0.1:1080
LOG_LEVEL=info

# Shared key between backend and clients. Leave empty to disable X-API-Key auth.
DEAL_SENSE_API_KEY=

# Per-IP rate limit (defence-in-depth). RPS=0 disables.
# Recommended for production: RPS=0.5 + BURST=30 (~30 req/min cap, short spikes allowed).
RATE_LIMIT_RPS=0
RATE_LIMIT_BURST=30

# Telegram bot (optional `telegram-bot` compose service)
# Start it with: docker compose --profile telegram up -d telegram-bot
TELEGRAM_BOT_TOKEN=
ALLOWLIST_USER_IDS=

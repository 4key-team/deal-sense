LLM_PROVIDER=anthropic
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=sk-ant-api03-your-key-here
LLM_MODEL=claude-sonnet-4-5
LOG_LEVEL=info

# Shared key between backend and clients. Leave empty to disable X-API-Key auth.
DEAL_SENSE_API_KEY=

# Telegram bot (optional `telegram-bot` compose service)
# Start it with: docker compose --profile telegram up -d telegram-bot
TELEGRAM_BOT_TOKEN=
ALLOWLIST_USER_IDS=
